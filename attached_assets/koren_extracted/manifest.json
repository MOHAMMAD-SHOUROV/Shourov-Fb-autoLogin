{
  "manifest_version": 3,
  "name": "Shourov-Fb-AutoLogin — FB Login Tool",
  "short_name": "Shourov FB",
  "version": "1.3.0",
  "description": "Auto Facebook Login with 2FA TOTP support. Works in background. Developed by Alihsan Shourov.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shourov-Fb-AutoLogin",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://m.facebook.com/*",
    "https://www.google.com/*"
  ]
}
